# Database (use Docker: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=nutritionist_booking postgres:16-alpine)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nutritionist_booking?schema=public"

# Next.js
NEXTAUTH_SECRET="your-secret-for-sessions"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp Business Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN="your-meta-whatsapp-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
WHATSAPP_APP_SECRET="your-app-secret-for-webhook-signature"
WHATSAPP_API_VERSION="v21.0"

# OpenAI
OPENAI_API_KEY="sk-..."

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID="your-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CALENDAR_CLIENT_SECRET="your-oauth-client-secret"
GOOGLE_CALENDAR_REFRESH_TOKEN="your-refresh-token"
GOOGLE_CALENDAR_ID="primary"

# Admin (for seed)
ADMIN_EMAIL="admin@clinic.local"
ADMIN_PASSWORD="changeme123"
